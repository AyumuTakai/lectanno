{
  "name": "lectanno",
  "version": "1.0.7",
  "description": "講義・研修向けアノテーション機能付きデスクトップブラウザ",
  "main": "main.js",
  "author": "Ayumu Takai <ayumu.takai@gmail.com>",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dist": "node scripts/build.js",
    "dist:mac": "node scripts/build.js mac",
    "dist:win": "node scripts/build.js win",
    "dist:linux": "node scripts/build.js linux"
  },
  "build": {
    "appId": "jp.ayumu.lectanno",
    "productName": "Lectanno",
    "copyright": "Copyright © 2025 Ayumu Takai",
    "icon": "build/icon.png",
    "files": [
      "**/*",
      "!scripts/**",
      "!dist/**",
      "!build/**",
      "!.vscode/**",
      "!*.md"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lectanno",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "keywords": [],
  "devDependencies": {
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8"
  }
}
