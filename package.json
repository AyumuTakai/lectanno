{
  "name": "anotbrowser",
  "version": "1.0.4",
  "description": "アノテーション機能付きデスクトップブラウザ",
  "main": "main.js",
  "author": "Ayumu Takai <ayumu.takai@gmail.com>",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dist": "node scripts/build.js",
    "dist:mac": "node scripts/build.js mac",
    "dist:win": "node scripts/build.js win",
    "dist:linux": "node scripts/build.js linux"
  },
  "build": {
    "appId": "jp.ayumu.anotbrowser",
    "productName": "AnotBrowser",
    "copyright": "Copyright © 2025 Ayumu Takai",
    "icon": "build/icon.png",
    "files": [
      "**/*",
      "!scripts/**",
      "!dist/**",
      "!build/**",
      "!.vscode/**",
      "!*.md"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "keywords": [],
  "devDependencies": {
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8"
  }
}
